# Required for real AI chat (omit or leave empty + set LLM_MOCK=true for offline)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Optional: real market data via Massive/Polygon. Empty = GBM simulator.
MASSIVE_API_KEY=

# Set true for deterministic mock LLM (tests / no API key)
LLM_MOCK=false

# Optional overrides
# DB_PATH=db/finally.db
# PORT=8000
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
